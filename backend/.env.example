# ── Local SQLite (Django default) ──────────────────────────────
# Used for: Stock, Sector, NepseIndex, NewsEvent models
# Chat history, users, vector RAG metadata
# No DATABASE_URL needed — SQLite is Django's default

# ── Neon DB (Read-only, for OHLCV data) ────────────────────────
# Get connection string from: console.neon.tech → your project → Connect
NEON_DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/nepse_db?sslmode=require

# ── LLM Fallback Chain ─────────────────────────────────────────
# Priority 1: Groq (fastest, free) — console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxx
# Priority 2: Google AI Studio (best quality, free) — aistudio.google.com
GOOGLE_AI_API_KEY=AIzaxxxxxxxxxxxxxxxxx
# Priority 3: OpenRouter (model variety, free tier) — openrouter.ai
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx
# Priority 4: Ollama — no key needed, runs locally
# Install: https://ollama.com → then: ollama pull llama3.2:3b

# ── Web Search Fallback Chain ──────────────────────────────────
# Priority 1: NewsAPI (100 req/day free) — newsapi.org
#   Sign up at: https://newsapi.org/register (no credit card)
NEWSAPI_KEY=your_newsapi_key_here

# Priority 2: Google Custom Search (100 req/day free)
#   See GOOGLE_CSE_SETUP.md for step-by-step instructions
GOOGLE_CSE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_search_engine_cx_id_here

# Priority 3: SerpAPI (100 req/month free) — serpapi.com
#   Sign up at: https://serpapi.com/users/sign_up (no credit card)
SERPAPI_KEY=your_serpapi_key_here

# Priority 4: DuckDuckGo — no key needed, unlimited

# ── Django ─────────────────────────────────────────────────────
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Cache ──────────────────────────────────────────────────────
# Use 'file' for development, 'redis' if Redis is available
CACHE_BACKEND=file
REDIS_URL=redis://localhost:6379/0

# ── Paths ──────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
INDEX_PATH=./indexes
LOG_PATH=./logs

# ── Neon Keep-Alive ────────────────────────────────────────────
# Ping interval in seconds to prevent Neon cold starts (default: 240)
NEON_KEEPALIVE_INTERVAL=240
